    TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
    task.wait(0.4)
    MainFrame.Visible = false
    MiniIcon.Visible = true
end

local function Maximize()
    MenuOpen = true
    MiniIcon.Visible = false
    MainFrame.Visible = true
    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(0, 350, 0, 500), Position = UDim2.new(0.5, -175, 0.5, -250)}):Play()
end

