local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local lp = Players.LocalPlayer
local Balls = Workspace:WaitForChild("Balls")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local parryRemote = Remotes:WaitForChild("ParryButtonPress")

local Settings = {
    ParryDist = 35, HitDist = 25, Predict = 0.08,
    Debug = false, Parry = false, Hit = false, Viz = false
}

local circleViz = nil

local function createViz()
    if circleViz then circleViz:Destroy() end
    circleViz = Instance.new("Part")
    circleViz.Name = "Viz"
    circleViz.Parent = Workspace
    circleViz.Anchored = true
    circleViz.CanCollide = false
    circleViz.Shape = Enum.PartType.Cylinder
    circleViz.Size = Vector3.new(1,0.1,1)
    circleViz.Material = Enum.Material.Neon
    circleViz.BrickColor = BrickColor.new("Bright red")
    circleViz.Transparency = 0.3
    Instance.new("SpecialMesh", circleViz).MeshType = Enum.MeshType.Cylinder
end

local function getBall()
    for _,b in Balls:GetChildren() do
        if b:IsA("BasePart") and b:GetAttribute("realBall") and b:GetAttribute("target") == lp.Name and b:FindFirstChild("zoomies") then
            return b
        end
    end
end

local conn
local function loop()
    if conn then conn:Disconnect() end
    conn = RunService.Heartbeat:Connect(function()
        if not (Settings.Parry or Settings.Hit) then
            if circleViz then circleViz.Visible = false end
            return
        end
        local char = lp.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local root = char.HumanoidRootPart
        local ball = getBall()
        if ball and Settings.Viz then
            circleViz.Position = ball.Position + Vector3.new(0,2,0)
            local vel = ball.zoomies.VectorVelocity.Magnitude
            local size = math.clamp(100/vel, 5, 50)
            circleViz.Size = Vector3.new(size, 0.1, size)
            circleViz.Visible = true
            circleViz.BrickColor = ( (ball.Position - root.Position).Magnitude <= Settings.ParryDist ) and BrickColor.new("Bright green") or BrickColor.new("Bright red")
        elseif circleViz then circleViz.Visible = false end
        if ball then
            local vel = ball.zoomies.VectorVelocity
            local dist = (ball.Position - root.Position).Magnitude
            local t = dist / vel.Magnitude
            local pred = ball.Position + vel * (t + Settings.Predict)
            local pDist = (pred - root.Position).Magnitude
            if Settings.Parry and pDist <= Settings.ParryDist then parryRemote:FireServer() end
            if Settings.Hit and pDist <= Settings.HitDist then parryRemote:FireServer() end
        end
    end)
end

