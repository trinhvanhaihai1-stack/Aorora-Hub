local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")

local function checkToSConfirmed()
    local success = pcall(function()
        return readfile("nodex_confirm_tos.txt")
    end)
    return success
end

local function createToSFile()
    local success = pcall(function()
        writefile("nodex_confirm_tos.txt", "confirmed")
    end)
    return success
end

-- MAIN SCRIPT (RAYFIELD MENU)
local function executeMain()

    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

    local Window = Rayfield:CreateWindow({
        Name = "Aurora Hub | Bóng Lưỡi",
        LoadingTitle = "Rayfield UI System",
        LoadingSubtitle = "by trinhvanhai21",
        ConfigurationSaving = {
            Enabled = true,
            FolderName = "AuroraHubConfigs",
            FileName = "SoloConfigFix"
        }
    })

end

