-- Blade Ball GOD + Viz (Fixed)

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local lp = Players.LocalPlayer
local Balls = Workspace:WaitForChild("Balls")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local parryRemote = Remotes:WaitForChild("ParryButtonPress")

local Settings = {
    ParryDist = 35,
    HitDist = 25,
    Predict = 0.08,
    Debug = false,
    Parry = false,
    Hit = false,
    Viz = false
}

local circleViz
local conn
local lastParry = 0
local cooldown = 0.15

-- create circle
local function createViz()
    if circleViz then circleViz:Destroy() end

    circleViz = Instance.new("Part")
    circleViz.Name = "Viz"
    circleViz.Parent = Workspace
    circleViz.Anchored = true
    circleViz.CanCollide = false
    circleViz.Shape = Enum.PartType.Cylinder
    circleViz.Size = Vector3.new(10,0.1,10)
    circleViz.Material = Enum.Material.Neon
    circleViz.BrickColor = BrickColor.new("Bright red")
    circleViz.Transparency = 0.3
end

-- detect ball
local function getBall()
    for _,b in pairs(Balls:GetChildren()) do
        if b:IsA("BasePart") then
            local target = b:GetAttribute("target")
            if target == lp.Name then
                return b
            end
        end
    end
end

-- main loop
local function loop()

    if conn then conn:Disconnect() end

    conn = RunService.Heartbeat:Connect(function()

        if not (Settings.Parry or Settings.Hit) then
            if circleViz then
                circleViz.Transparency = 1
            end
            return
        end

        local char = lp.Character
        if not char then return end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local ball = getBall()
        if not ball then return end

        local vel = ball.AssemblyLinearVelocity
        local speed = vel.Magnitude

        if speed < 1 then return end

        local dist = (ball.Position - root.Position).Magnitude
        local t = dist / speed

        local pred = ball.Position + vel * (t + Settings.Predict)
        local pDist = (pred - root.Position).Magnitude

        -- viz
        if Settings.Viz and circleViz then
            circleViz.Position = root.Position - Vector3.new(0,2,0)

            local size = math.clamp(100/(speed+1),5,50)
            circleViz.Size = Vector3.new(size,0.1,size)

            circleViz.Transparency = 0.3

            if pDist <= Settings.ParryDist then
                circleViz.BrickColor = BrickColor.new("Bright green")
            else
                circleViz.BrickColor = BrickColor.new("Bright red")
            end
        elseif circleViz then
            circleViz.Transparency = 1
        end

        -- parry
        if Settings.Parry and pDist <= Settings.ParryDist then
            if tick() - lastParry > cooldown then
                lastParry = tick()
                parryRemote:FireServer()
            end
        end

        -- hit
        if Settings.Hit and pDist <= Settings.HitDist then
            if tick() - lastParry > cooldown then
                lastParry = tick()
                parryRemote:FireServer()
            end
        end

    end)

end

-- GUI
local sg = Instance.new("ScreenGui")
sg.Parent = game.CoreGui
sg.Name = "BBGod"
sg.ResetOnSpawn = false

local frame = Instance.new("Frame", sg)
frame.BackgroundColor3 = Color3.fromRGB(25,25,35)
frame.Position = UDim2.new(0.5,-170,0.3,-145)
frame.Size = UDim2.new(0,340,0,290)
frame.Active = true
frame.Draggable = true
Instance.new("UICorner", frame)

local tb = Instance.new("Frame", frame)
tb.BackgroundColor3 = Color3.fromRGB(15,15,25)
tb.Size = UDim2.new(1,0,0,45)
Instance.new("UICorner", tb)

local title = Instance.new("TextLabel", tb)
title.BackgroundTransparency = 1
title.Size = UDim2.new(1,-80,1,0)
title.Font = Enum.Font.GothamBold
title.Text = "Blade Ball GOD + Viz"
title.TextColor3 = Color3.new(1,1,1)
title.TextSize = 15
title.TextXAlignment = Enum.TextXAlignment.Left

local minBtn = Instance.new("TextButton", tb)
minBtn.Position = UDim2.new(1,-65,0,10)
minBtn.Size = UDim2.new(0,25,0,25)
minBtn.Text = "-"
Instance.new("UICorner", minBtn)

local closeBtn = Instance.new("TextButton", tb)
closeBtn.Position = UDim2.new(1,-35,0,10)
closeBtn.Size = UDim2.new(0,25,0,25)
closeBtn.Text = "X"
Instance.new("UICorner", closeBtn)

local cont = Instance.new("Frame", frame)
cont.BackgroundTransparency = 1
cont.Position = UDim2.new(0,10,0,55)
cont.Size = UDim2.new(1,-20,1,-65)

-- parry toggle
local pToggle = Instance.new("TextButton", cont)
pToggle.Size = UDim2.new(0.48,0,0,35)
pToggle.Text = "PARRY: TẮT"

-- hit toggle
local hToggle = Instance.new("TextButton", cont)
hToggle.Position = UDim2.new(0.52,0,0,0)
hToggle.Size = UDim2.new(0.48,0,0,35)
hToggle.Text = "HIT: TẮT"

-- viz toggle
local vToggle = Instance.new("TextButton", cont)
vToggle.Position = UDim2.new(0,0,0,45)
vToggle.Size = UDim2.new(1,0,0,35)
vToggle.Text = "CIRCLE VIZ: TẮT"

-- actions
pToggle.MouseButton1Click:Connect(function()
    Settings.Parry = not Settings.Parry
    pToggle.Text = "PARRY: "..(Settings.Parry and "BẬT" or "TẮT")
    loop()
end)

hToggle.MouseButton1Click:Connect(function()
    Settings.Hit = not Settings.Hit
    hToggle.Text = "HIT: "..(Settings.Hit and "BẬT" or "TẮT")
    loop()
end)

vToggle.MouseButton1Click:Connect(function()
    Settings.Viz = not Settings.Viz
    vToggle.Text = "CIRCLE VIZ: "..(Settings.Viz and "BẬT" or "TẮT")

    if Settings.Viz then
        createViz()
    elseif circleViz then
        circleViz.Transparency = 1
    end

    loop()
end)

-- minimize
local min = false
minBtn.MouseButton1Click:Connect(function()

    min = not min

    if min then
        TweenService:Create(frame,TweenInfo.new(0.3),{Size=UDim2.new(0,340,0,45)}):Play()
        cont.Visible = false
    else
        TweenService:Create(frame,TweenInfo.new(0.3),{Size=UDim2.new(0,340,0,290)}):Play()
        cont.Visible = true
    end

end)

-- close
closeBtn.MouseButton1Click:Connect(function()

    if conn then conn:Disconnect() end
    if circleViz then circleViz:Destroy() end

    sg:Destroy()

end)

game.StarterGui:SetCore("SendNotification",{
Title="GOD + VIZ",
Text="Script Loaded",
Duration=4
})
