-- ====================== AUTO PARRY LOGIC ======================
local function StartAutoParry()
    -- Load visualizer (gốc)
    loadstring(game:HttpGet("https://scriptblox.com/raw/UPD-Blade-Ball-op-autoparry-with-visualizer-8652"))()
    
    -- Notification (gốc)
    StarterGui:SetCore("SendNotification", {
        Title = "NoEnemiesHub",
        Text = "Auto Parry Executed (We also added visualizer.)",
        Icon = "rbxassetid://135351041318579",
        Duration = 10,
        Button1 = "OK"
    })
    
    -- Ball ChildAdded
    table.insert(AutoParryConnections, workspace.Balls.ChildAdded:Connect(function()
        local Ball = GetBall()
        if not Ball then return end
        ResetConnection()
        Connection = Ball:GetAttributeChangedSignal("target"):Connect(function()
            IsParried = false
        end)
    end))
    
    -- Main loop
    table.insert(AutoParryConnections, RunService.PreSimulation:Connect(function()
        local Ball, HRP = GetBall(), player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not Ball or not HRP then return end
        
        local Speed = Ball.zoomies.VectorVelocity.Magnitude
        local Distance = (HRP.Position - Ball.Position).Magnitude
        
        if Ball:GetAttribute("target") == player.Name and not IsParried and Distance / Speed <= 0.55 then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            IsParried = true
            Cooldown = tick()
            
            if (tick() - Cooldown) >= 1 then
                IsParried = false
            end
        end
    end))
    
    StatusLabel.Text = "ON - Auto Parry Active!"
    StatusLabel.TextColor3 = Color3.fromRGB(50, 200, 50)
end

local function StopAutoParry()
    for _, conn in ipairs(AutoParryConnections) do
        if conn then conn:Disconnect() end
    end
    AutoParryConnections = {}
    ResetConnection()
    IsParried = false
    StatusLabel.Text = "OFF - Ready"
    StatusLabel.TextColor3 = Color3.fromRGB(200, 50, 50)
end

-- ====================== TOGGLE FUNCTION ======================
local function UpdateToggle()
    if AutoParryEnabled then
        TweenService:Create(Knob, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 43, 0.5, -17)}):Play()
        TweenService:Create(Knob, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 200, 50)}):Play()
        TweenService:Create(SwitchBG, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 100, 40)}):Play()
        StartAutoParry()
    else
        TweenService:Create(Knob, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 3, 0.5, -17)}):Play()
        TweenService:Create(Knob, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
        TweenService:Create(SwitchBG, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 50, 60)}):Play()
        StopAutoParry()
    end
end

